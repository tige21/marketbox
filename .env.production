VITE_API_URL=https://marketandbox.ru
VITE_TG_BOT_USERNAME=Marketbox_expert_bot
VITE_APP_ENV=production
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production
VITE_MOCK_TG=false
# Keep MSW in prod to intercept auth/profile/favorites/money/exchange
# paths (backend has no CRUD for those). All other `/api/*` requests
# fall through via `onUnhandledRequest: 'bypass'` and hit
# VITE_API_URL directly.
VITE_USE_MOCKS=true
