# MarketBox Mini App — SPA fallback under /app/
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve real files / directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # All other paths fall back to /app/index.html (React Router handles routing)
  RewriteRule ^ /app/index.html [L]
</IfModule>

# Long cache for hashed assets
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|svg|png|jpg|jpeg|webp)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
